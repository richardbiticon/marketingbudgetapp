# Neon Postgres connection string. Required.
# Create a free database at https://neon.tech, then copy the pooled
# connection string here. It looks like:
# postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# Shared secret for the inbound test-email webhook (/api/inbound?key=...).
# Make up any long random string and use the same one in your inbound-parse
# service (CloudMailin / Postmark / SendGrid) target URL.
INBOUND_SECRET=
